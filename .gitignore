# Ignore the contents of the _site directory and other cache directories
_site/
.sass-cache/

# Ignore the directory for local files during development
local/

# Ignore the Gemfile that is generated
Gemfile.lock

# Ingore files created by npm
node_modules
package-lock.json

# Ignore bundler's gem directory at the repo root only
# (a bare "vendor" pattern would wrongly ignore _sass/vendor/, which the
# stylesheet build needs)
/vendor/
.bundle/

# macOS
.DS_Store
